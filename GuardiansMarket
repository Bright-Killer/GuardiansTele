<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TOPUP.ID - Owner Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-950 text-white">
  <!-- LOGIN -->
  <div id="loginScreen" class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 to-black">
    <div class="bg-gray-900 p-10 rounded-3xl w-96">
      <h1 class="text-4xl font-bold text-green-400 text-center mb-2">🎮 TOPUP.ID</h1>
      <p class="text-center text-gray-400 mb-8">Owner Dashboard 2026</p>
      <input id="username" placeholder="Username: admin" class="w-full p-4 bg-gray-800 rounded-2xl mb-4">
      <input id="password" type="password" placeholder="Password: topup123" class="w-full p-4 bg-gray-800 rounded-2xl mb-6">
      <button onclick="handleLogin()" class="w-full bg-green-500 py-4 rounded-2xl font-bold text-lg">LOGIN ADMIN</button>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboardScreen" class="hidden flex h-screen">
    <div class="w-72 bg-gray-900 p-6 flex flex-col border-r border-gray-800">
      <h1 class="text-3xl font-bold text-green-400 mb-10 flex items-center gap-3"><span>🎮</span>TOPUP.ID</h1>
      <nav class="flex-1 space-y-2">
        <a onclick="navigateTo('home')" class="flex items-center gap-3 p-4 hover:bg-gray-800 rounded-2xl cursor-pointer">🏠 Dashboard</a>
        <a onclick="navigateTo('products')" class="flex items-center gap-3 p-4 hover:bg-gray-800 rounded-2xl cursor-pointer">📦 Produk Game</a>
        <a onclick="navigateTo('trading')" class="flex items-center gap-3 p-4 hover:bg-gray-800 rounded-2xl cursor-pointer">🔄 Trading</a>
        <a onclick="navigateTo('orders')" class="flex items-center gap-3 p-4 hover:bg-gray-800 rounded-2xl cursor-pointer">📋 Orders</a>
        <a onclick="navigateTo('telegram')" class="flex items-center gap-3 p-4 hover:bg-gray-800 rounded-2xl cursor-pointer">🤖 Telegram Bot</a>
      </nav>
      <button onclick="logout()" class="mt-auto text-red-400 hover:bg-gray-800 p-4 rounded-2xl flex items-center gap-3"><i class="fas fa-sign-out-alt"></i> Logout</button>
    </div>
    <div class="flex-1 overflow-auto p-8" id="mainContent"></div>
  </div>

  <script>
    // DATA (sama seperti sebelumnya)
    let products = [
      {id:1, game:"Mobile Legends", icon:"⚔️", packages:[{name:"12 Diamonds", price:3500},{name:"85 Diamonds", price:23000},{name:"366 Diamonds", price:100000}]},
      {id:2, game:"Free Fire", icon:"🔥", packages:[{name:"50 Diamonds", price:7207},{name:"140 Diamonds", price:18018},{name:"1450 Diamonds", price:180180}]},
      {id:3, game:"Genshin Impact", icon:"🌟", packages:[{name:"60 Genesis Crystals", price:13000},{name:"300+30 Genesis Crystals", price:81000},{name:"3280+600 Genesis Crystals", price:489000}]},
      {id:4, game:"PUBG Mobile", icon:"🎯", packages:[{name:"60 UC", price:15999},{name:"325 UC", price:78000},{name:"660 UC", price:156000}]}
    ];
    let orders = [{id:101, user:"@rizky123", game:"Mobile Legends", paket:"85 Diamonds", uid:"123456789", amount:23000, status:"pending"}];
    let trades = [{id:1, game:"MLBB Akun Mythic", item:"Skin Legend + 5000 DM", price:450000, status:"Available"}];

    let botToken = localStorage.getItem('botToken') || '';
    let botInfo = JSON.parse(localStorage.getItem('botInfo') || '{}');

    // LOGIN & NAV (sama)
    function handleLogin() { /* sama seperti sebelumnya */ }
    if (localStorage.getItem('loggedIn') === 'true') {
      document.getElementById('loginScreen').classList.add('hidden');
      document.getElementById('dashboardScreen').classList.remove('hidden');
      navigateTo('home');
    }
    function logout() { localStorage.clear(); location.reload(); }

    function navigateTo(page) {
      const content = document.getElementById('mainContent');
      if (page === 'telegram') {
        content.innerHTML = `
          <h2 class="text-3xl font-bold mb-8 flex items-center gap-3"><i class="fas fa-robot"></i> Telegram Bot + Webhook</h2>
          <div class="max-w-3xl bg-gray-900 p-10 rounded-3xl">
            <!-- Token Section -->
            <div class="mb-10">
              <label class="block text-sm mb-2">Bot Token</label>
              <input id="tokenInput" type="text" value="${botToken}" class="w-full p-5 bg-gray-800 rounded-2xl font-mono">
              <button onclick="validateToken()" class="mt-4 bg-blue-600 px-8 py-3 rounded-2xl">Validasi Token</button>
            </div>

            <!-- Webhook Section -->
            <div class="border-t border-gray-700 pt-8">
              <h3 class="text-2xl font-bold mb-6 flex items-center gap-3"><i class="fas fa-link"></i> Webhook Management</h3>
              <div class="mb-6">
                <label class="block text-sm mb-2 font-medium">Webhook URL (harus HTTPS & public)</label>
                <input id="webhookUrl" type="url" placeholder="https://nama-anda.vercel.app/api/webhook" class="w-full p-5 bg-gray-800 rounded-2xl text-lg">
              </div>
              <div class="grid grid-cols-3 gap-4">
                <button onclick="setWebhook()" class="bg-green-600 py-5 rounded-2xl font-bold">🚀 SET WEBHOOK</button>
                <button onclick="getWebhookInfo()" class="bg-blue-600 py-5 rounded-2xl font-bold">ℹ️ Get Info</button>
                <button onclick="deleteWebhook()" class="bg-red-600 py-5 rounded-2xl font-bold">🗑️ Delete Webhook</button>
              </div>

              <div id="webhookStatus" class="mt-8 p-6 bg-gray-800 rounded-2xl text-sm hidden">
                <!-- diisi oleh JS -->
              </div>
            </div>
          </div>`;
      } else if (page === 'products') { /* kode products sama */ }
      else if (page === 'orders') { /* kode orders sama */ }
      else if (page === 'trading') { content.innerHTML = `<h2 class="text-3xl font-bold mb-8">Trading Section</h2>`; }
      else { content.innerHTML = `<h2 class="text-3xl font-bold">Selamat Datang! Webhook sudah aktif di menu Telegram Bot.</h2>`; }
    }

    // === WEBHOOK FUNCTIONS ===
    async function setWebhook() {
      const url = document.getElementById('webhookUrl').value.trim();
      if (!botToken || !url) return alert('Token atau URL kosong!');
      try {
        const res = await fetch(`https://api.telegram.org/bot${botToken}/setWebhook?url=${encodeURIComponent(url)}`);
        const data = await res.json();
        if (data.ok) alert(`✅ Webhook berhasil di-set!\nURL: ${url}`);
        else alert('❌ Gagal: ' + data.description);
      } catch(e) { alert('Gagal konek ke Telegram'); }
    }

    async function getWebhookInfo() {
      if (!botToken) return alert('Token belum di-set!');
      const statusDiv = document.getElementById('webhookStatus');
      try {
        const res = await fetch(`https://api.telegram.org/bot${botToken}/getWebhookInfo`);
        const data = await res.json();
        if (data.ok) {
          const info = data.result;
          statusDiv.classList.remove('hidden');
          statusDiv.innerHTML = `
            <p><strong>URL:</strong> ${info.url || 'Tidak ada'}</p>
            <p><strong>Pending Update:</strong> ${info.pending_update_count}</p>
            <p><strong>Last Sync:</strong> ${info.last_synchronization_error_date ? new Date(info.last_synchronization_error_date*1000).toLocaleString('id-ID') : 'OK'}</p>
            <p><strong>Max Connections:</strong> ${info.max_connections || '-'}</p>
          `;
        }
      } catch(e) { alert('Gagal'); }
    }

    async function deleteWebhook() {
      if (!botToken) return;
      if (!confirm('Hapus webhook dan kembali ke polling?')) return;
      try {
        const res = await fetch(`https://api.telegram.org/bot${botToken}/deleteWebhook`);
        const data = await res.json();
        if (data.ok) alert('✅ Webhook dihapus!');
      } catch(e) {}
    }

    // Fungsi lama (validateToken, confirmOrder, editPrice) tetap ada
    async function validateToken() { /* sama seperti sebelumnya */ }
    function confirmOrder(id) { /* sama */ }
    function editPrice(id, name, oldPrice) { /* sama */ }

    window.onload = () => { if (localStorage.getItem('loggedIn') === 'true') navigateTo('home'); };
  </script>
</body>
</html>
